final class HostingViewController: UIViewController {
    private var hostingController: UIHostingController<Screen>?
    private var selectedTab: Binding<AppTab>
    private let namespace: Namespace.ID

    init(
        selectedTab: Binding<AppTab>,
        namespace: Namespace.ID
    ) {
        self.selectedTab = selectedTab
        self.namespace = namespace
        super.init(nibName: nil, bundle: nil)
    }

    @available(*, unavailable)
    required init?(coder: NSCoder) {
        fatalError("init(coder:) has not been implemented")
    }

    override func viewDidLoad() {
        super.viewDidLoad()
        embedSwiftUIView()
    }

    func update(
        selectedTab: Binding<AppTab>,
        namespace: Namespace.ID
    ) {
        self.selectedTab = selectedTab

        // Namespace.ID w praktyce zwykle jest stały w cyklu życia widoku.
        // Jeśli chcesz go też odświeżać, najlepiej przebudować hosting controller.
        if self.namespace != namespace {
            replaceRootView(selectedTab: selectedTab, namespace: namespace)
        } else {
            hostingController?.rootView = Screen(
                selectedTab: selectedTab,
                namespace: namespace
            )
        }
    }

    private func embedSwiftUIView() {
        let swiftUIView = Screen(
            selectedTab: selectedTab,
            namespace: namespace
        )

        let hostingController = UIHostingController(rootView: swiftUIView)
        self.hostingController = hostingController

        addChild(hostingController)
        view.addSubview(hostingController.view)
        hostingController.view.translatesAutoresizingMaskIntoConstraints = false

        NSLayoutConstraint.activate([
            hostingController.view.topAnchor.constraint(equalTo: view.topAnchor),
            hostingController.view.bottomAnchor.constraint(equalTo: view.bottomAnchor),
            hostingController.view.leadingAnchor.constraint(equalTo: view.leadingAnchor),
            hostingController.view.trailingAnchor.constraint(equalTo: view.trailingAnchor)
        ])

        hostingController.didMove(toParent: self)
    }

    private func replaceRootView(
        selectedTab: Binding<AppTab>,
        namespace: Namespace.ID
    ) {
        guard let oldHostingController = hostingController else {
            embedSwiftUIView()
            return
        }

        oldHostingController.willMove(toParent: nil)
        oldHostingController.view.removeFromSuperview()
        oldHostingController.removeFromParent()

        let newSwiftUIView = Screen(
            selectedTab: selectedTab,
            namespace: namespace
        )

        let newHostingController = UIHostingController(rootView: newSwiftUIView)
        self.hostingController = newHostingController

        addChild(newHostingController)
        view.addSubview(newHostingController.view)
        newHostingController.view.translatesAutoresizingMaskIntoConstraints = false

        NSLayoutConstraint.activate([
            newHostingController.view.topAnchor.constraint(equalTo: view.topAnchor),
            newHostingController.view.bottomAnchor.constraint(equalTo: view.bottomAnchor),
            newHostingController.view.leadingAnchor.constraint(equalTo: view.leadingAnchor),
            newHostingController.view.trailingAnchor.constraint(equalTo: view.trailingAnchor)
        ])

        newHostingController.didMove(toParent: self)
    }
}


// MARK: - 2. SwiftUI wrapper używający HostingViewController
struct HostedScreen: UIViewControllerRepresentable {
    @Binding var selectedTab: AppTab
    let namespace: Namespace.ID

    func makeUIViewController(context: Context) -> HostingViewController {
        HostingViewController(
            selectedTab: $selectedTab,
            namespace: namespace
        )
    }

    func updateUIViewController(
        _ uiViewController: HostingViewController,
        context: Context
    ) {
        uiViewController.update(
            selectedTab: $selectedTab,
            namespace: namespace
        )
    }
}
