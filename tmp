import SwiftUI

enum AppTab: String, CaseIterable {
    case home = "Home"
    case search = "Szukaj"
    case settings = "Ustawienia"
    
    var backgroundColor: Color {
        switch self {
        case .home:
                .red
        case .search:
                .blue
        case .settings:
                .green
        }
    }
}

struct AnimatedTabBarExample: View {
    @State private var selectedTab: AppTab = .home
    @Namespace private var namespace
    
    var body: some View {
        switch selectedTab {
        case .home:
            HostedScreen(selectedTab: $selectedTab, namespace: namespace)
        case .search:
            HostedScreen(selectedTab: $selectedTab, namespace: namespace)
        case .settings:
            Screen3(selectedTab: $selectedTab, namespace: namespace)
        }
        
    }
}



struct Screen: View {
    @Binding var selectedTab: AppTab
    let namespace: Namespace.ID
    
    var body: some View {
        VStack {
            Spacer()
            
            Text("Wybrany tab: \(selectedTab.rawValue)")
                .font(.title)
            
            Spacer()
            
            AnimatedTabBar(
                selectedTab: $selectedTab,
                namespace: namespace
            )
        }
        .background(selectedTab.backgroundColor.opacity(0.2))
    }
}

